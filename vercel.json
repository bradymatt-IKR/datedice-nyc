{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "functions": {
    "api/search.js": {
      "maxDuration": 60
    },
    "api/stream.js": {
      "maxDuration": 60,
      "supportsResponseStreaming": true
    }
  },
  "fluid": true
}
